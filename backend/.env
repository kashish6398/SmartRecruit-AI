# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/smartrecruit_new

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
